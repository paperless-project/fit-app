# Copia este fichero a `.env` y ajusta los valores.

# --- PostgreSQL ---
POSTGRES_USER=fitapp
POSTGRES_PASSWORD=fitapp
POSTGRES_DB=fitapp
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- API ---
# Secret para firmar JWTs. Minimo 32 bytes (256 bits). Generar con: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_LIFETIME_SECONDS=28800

# CORS: origenes permitidos separados por coma
CORS_ORIGINS=http://localhost:5173

# Path dentro del contenedor donde se monta /workspace/xabi/Activities
ACTIVITIES_DIR=/activities

# --- Google OAuth (opcional — necesario para "Acceder con Google") ---
# Crea un OAuth 2.0 Client ID en console.cloud.google.com > APIs & Services > Credentials
# Authorized redirect URI: {API_URL}/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Strava OAuth (opcional — necesario para importar actividades desde Strava) ---
# Crea una app en https://www.strava.com/settings/api
# Authorization Callback Domain: localhost (en dev) o tu dominio en producción
# Redirect URI configurada automáticamente como: {API_URL}/strava/callback
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# --- URLs (API_URL se usa tanto en backend como en frontend vía VITE_API_URL) ---
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
