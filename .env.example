# Copia este fichero a `.env` y ajusta los valores.

# --- PostgreSQL ---
POSTGRES_USER=fitapp
POSTGRES_PASSWORD=fitapp
POSTGRES_DB=fitapp
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- API ---
# Secret para firmar JWTs. En produccion: usar una cadena aleatoria larga.
JWT_SECRET=change-me-in-production-please
JWT_LIFETIME_SECONDS=3600

# CORS: origenes permitidos separados por coma
CORS_ORIGINS=http://localhost:5173

# Path dentro del contenedor donde se monta /workspace/xabi/Activities
ACTIVITIES_DIR=/activities

# --- Web ---
VITE_API_URL=http://localhost:8000
